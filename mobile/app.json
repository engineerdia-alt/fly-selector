{
  "expo": {
    "name": "Fly Finder",
    "slug": "fly-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flyfinder",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flyfishinguniverse.flyfinder",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fly Finder uses your location to show nearby waters and live conditions.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flyfishinguniverse.flyfinder",
      "adaptiveIcon": {
        "backgroundColor": "#0F322C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F322C"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Fly Finder to use your location for nearby waters and conditions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "replace-before-eas-build"
      }
    }
  }
}
